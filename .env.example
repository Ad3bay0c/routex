# ── Routex environment variables ──────────────────────────────────
#
# DEVELOPMENT ONLY — copy this file to .env and fill in your keys.
# agents.yaml will load it automatically when env_file: "." is set.
#
# PRODUCTION — do NOT use .env files. Inject secrets through your
# deployment platform instead:
#
#   Docker          docker run -e ANTHROPIC_API_KEY=sk-... myimage
#   Kubernetes      use Secrets and envFrom in your pod spec
#   Fly.io          fly secrets set ANTHROPIC_API_KEY=sk-...
#   Railway         dashboard → project → environment variables
#   Heroku          heroku config:set ANTHROPIC_API_KEY=sk-...
#   AWS ECS         task definition environment / Secrets Manager
#   AWS Lambda      configuration → environment variables
#
# Never commit your .env file — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────

# ── LLM providers ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# ── Search tools ──────────────────────────────────────────────────
# Brave Search — https://api.search.brave.com (free: 2,000/month)
BRAVE_API_KEY=BSA-your-key-here

# ScrapingBee — https://www.scrapingbee.com (free: 1,000 credits/month)
SCRAPINGBEE_API_KEY=your-key-here

# ── Memory ────────────────────────────────────────────────────────
# Only needed when memory.backend is "redis" in agents.yaml
REDIS_URL=redis://localhost:6379

# ── Observability ─────────────────────────────────────────────────
# Only needed when observability.tracing is true
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
